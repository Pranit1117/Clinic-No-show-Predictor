# Copy this to .env and fill in your values
# NEVER commit .env to git

# OpenWeatherMap API (free tier works)
OPENWEATHER_API_KEY=your_api_key_here

# Kaggle credentials (for automated dataset download)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Database (optional — SQLite used by default locally)
DATABASE_URL=sqlite:///./clinic_noshow.db
# DATABASE_URL=postgresql://user:password@localhost:5432/clinic_noshow

# MLflow
MLFLOW_TRACKING_URI=mlruns

# Environment
ENV=development  # development | staging | production
